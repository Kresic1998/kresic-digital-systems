# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to .env.local and fill in values.
# NEVER commit .env.local. This file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Your production URL (used for Open Graph metadataBase and canonical URLs).
# Example: https://kresic.digital
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Resend — required for the contact form to deliver email.
# 1. Sign up at https://resend.com
# 2. Create an API key with "Sending access"
# 3. On Vercel: Project → Settings → Environment Variables
#    - Name:  RESEND_API_KEY  (must be exact)
#    - Environment: check "Production" (and "Preview" if you want)
#    - Click "Save", then manually trigger a Redeploy
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# Optional — verified sender domain, e.g. "Kresic Digital Systems <noreply@kresic.digital>"
# If unset, the form will return a "not configured" error in production.
# In development only, the Resend onboarding address is used as a fallback.
RESEND_FROM_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# eRecht24 Rechtstexte-API — opciono: sinhronizacija Impressum / Datenschutz
# Dokumentacija: https://api-docs.e-recht24.dev/ · PHP SDK (referenca): erecht24/rechtstexte-sdk
# 1. API key u Projekt Manageru (eRecht24 Mitgliederbereich)
# 2. Plugin key nakon potpisivanja API ugovora (api@e-recht24.de)
# 3. (Opciono) Registruj push klijenta; push URL:
#    https://<tvoj-domen>/api/erecht24/push?erecht24_secret=...&erecht24_type=...
#    ili isti query na GET/POST — vrednost secret-a kao ERECHT24_PUSH_SECRET
# ─────────────────────────────────────────────────────────────────────────────
# ERECHT24_API_KEY=
# ERECHT24_PLUGIN_KEY=
# ERECHT24_PUSH_SECRET=
# ERECHT24_API_BASE_URL=https://api.e-recht24.de
