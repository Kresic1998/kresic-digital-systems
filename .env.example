# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to .env.local and fill in values.
# NEVER commit .env.local. This file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Your production URL (used for Open Graph metadataBase and canonical URLs).
# Production site (Open Graph, sitemap, robots). Example: https://kresicds.com
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Resend — required for the contact form to deliver email.
# 1. Sign up at https://resend.com
# 2. Create an API key with "Sending access"
# 3. On Vercel: Project → Settings → Environment Variables
#    - Name:  RESEND_API_KEY  (must be exact)
#    - Environment: check "Production" (and "Preview" if you want)
#    - Click "Save", then manually trigger a Redeploy
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# Verified sender in Resend (your domain). Example:
#   RESEND_FROM_EMAIL="Kresic Digital Systems <noreply@yourdomain.com>"
# Required whenever NODE_ENV=production (Vercel, or `next start` locally).
# If unset in production, the contact form cannot send. `next dev` uses a Resend test sender instead.
RESEND_FROM_EMAIL=

# Optional inbox for contact-form notifications (default: SITE_EMAIL in lib/site.ts).
# Use if you want leads at e.g. you@yourdomain.com instead of the hardcoded address.
RESEND_TO_EMAIL=

# Optional single third-party script URL (analytics, tag manager). Loaded via
# next/script with strategy=lazyOnload — extend Content-Security-Policy script-src
# in next.config.mjs if the host is not already allowed.
NEXT_PUBLIC_DEFERRED_SCRIPT_SRC=

# Optional Subresource Integrity for the URL above (e.g. sha384-… from your CDN).
# Required crossOrigin="anonymous" is set automatically when this is present.
NEXT_PUBLIC_DEFERRED_SCRIPT_INTEGRITY=
